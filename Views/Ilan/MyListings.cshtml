@model IEnumerable<GuvenOto.Models.Ilan>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-list-stars text-primary"></i> İlanlarım</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> Yeni İlan Ekle
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Görsel</th>
                        <th>Araç / Başlık</th>
                        <th>Plaka</th>
                        <th>Fiyat</th>
                        <th>Tarih</th>
                        <th class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <img src="@(item.MainImageUrl ?? "/images/no-image.png")" class="rounded" style="width: 60px; height: 45px; object-fit: cover;">
                            </td>
                            <td>
                                <div class="fw-bold">@item.AracModeli?.Marka?.Name @item.AracModeli?.Name</div>
                                <small class="text-muted">@item.Title</small>
                            </td>
                            <td><span class="badge bg-secondary">@item.Plate</span></td>
                            <td class="fw-bold text-danger">@item.Price.ToString("N0") TL</td>
                            <td class="small">@item.CreatedDate.ToShortDateString()</td>
                            <td class="text-center">
                                <div class="btn-group shadow-sm">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu ilanı silmek istediğinize emin misiniz?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger border-start-0 rounded-end">
                                            <i class="bi bi-trash"></i> Sil
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>



