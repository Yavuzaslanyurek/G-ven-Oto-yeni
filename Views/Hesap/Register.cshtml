@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-lg" style="background: rgba(255, 255, 255, 0.9);">
                <div class="card-header bg-primary text-white text-center py-4">
                    <h3>Güven Oto'ya Katıl</h3>
                    <p class="mb-0">Kamyon ve araç ilanları için kayıt ol</p>
                </div>
                <div class="card-body p-5">
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">Adınız</label>
                            <input type="text" name="Name" class="form-control" placeholder="Örn: Ahmet" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Soyadınız</label>
                            <input type="text" name="Surname" class="form-control" placeholder="Örn: Yılmaz" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">E-Posta</label>
                            <input type="email" name="Email" class="form-control" placeholder="name@example.com" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Şifre</label>
                            <input type="password" name="Password" class="form-control" placeholder="******" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2 shadow">Kayıt Ol</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>