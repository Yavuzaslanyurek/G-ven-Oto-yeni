<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Güven Oto</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GuvenOto.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        .navbar-Marka {
            letter-spacing: 1px;
        }

        .nav-link:hover {
            color: #ffca2c !important;
            transition: 0.3s;
        }

        footer {
            position: relative;
            bottom: 0;
            width: 100%;
        }

        .dropdown-menu {
            border-radius: 12px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-Marka fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-truck"></i> GÜVEN OTO
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white fw-semibold" asp-controller="Ilan" asp-action="Index">
                                <i class="bi bi-list-ul"></i> İlanlar
                            </a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-info fw-semibold" asp-controller="Ilan" asp-action="MyListings">
                                    <i class="bi bi-person-lines-fill"></i> İlanlarım
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-bold" asp-controller="Ilan" asp-action="Create">
                                    <i class="bi bi-plus-circle-fill"></i> Ücretsiz İlan Ver
                                </a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="dropdown">
                                <button class="btn btn-outline-light dropdown-toggle btn-sm px-3 border-0" type="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="userMenu">
                                    <li><a class="dropdown-item py-2" asp-controller="Ilan" asp-action="MyListings"><i class="bi bi-card-list me-2"></i> İlanlarımı Yönet</a></li>
                                    <li><hr class="dropdown-divider"></li>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li class="px-3 py-1 small text-muted fw-bold text-uppercase" style="font-size: 0.7rem;">Admin</li>
                                        <li>
                                            <a class="dropdown-item py-2" asp-controller="Yonetici" asp-action="Ozellikler">
                                                <i class="bi bi-gear-wide-connected me-2"></i> Özellik Yönetimi
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item py-2" asp-controller="Yonetici" asp-action="Markalar">
                                                <i class="bi bi-tags-fill me-2"></i> Marka & Model Yönetimi
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                    }

                                    <li>
                                        <form asp-controller="Hesap" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item text-danger py-2">
                                                <i class="bi bi-box-arrow-right me-2"></i> Güvenli Çıkış
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-link text-white text-decoration-none btn-sm px-3" asp-controller="Hesap" asp-action="Login">Giriş Yap</a>
                            <a class="btn btn-primary btn-sm px-4 rounded-pill shadow-sm" asp-controller="Hesap" asp-action="Register">Kayıt Ol</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light py-4 mt-auto">
        <div class="container text-center">
            &copy; 2026 - <span class="text-dark fw-bold">Güven Oto</span> | Ticari Araç Yönetim Sistemi
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>



